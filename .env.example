# BAM Systematic Execution OS — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ── Asana credentials ──────────────────────────────────────────────────────────
ASANA_PERSONAL_ACCESS_TOKEN=your_pat_here
ASANA_WORKSPACE_GID=your_workspace_gid_here

# ── Asana project GIDs (set after Phase 1 Asana workspace setup) ───────────────
ASANA_PM_NEEDS_PROJECT_GID=
ASANA_PM_COVERAGE_PROJECT_GID=
ASANA_RISKS_PROJECT_GID=

# ── Asana custom field GIDs (populated by scripts/seed_config.py) ──────────────
ASANA_CUSTOM_FIELD_PM_ID=
ASANA_CUSTOM_FIELD_URGENCY=
ASANA_CUSTOM_FIELD_HEALTH=
ASANA_CUSTOM_FIELD_PRIORITY=
ASANA_CUSTOM_FIELD_BUSINESS_IMPACT=

# ── Asana webhook ──────────────────────────────────────────────────────────────
ASANA_WEBHOOK_SECRET=your_webhook_secret_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./bam_execution.db

# ── API server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Scheduler cron expressions ─────────────────────────────────────────────────
DAILY_DIGEST_CRON=0 7 * * *
WEEKLY_REVIEW_CRON=0 8 * * MON

# ── Alert thresholds (configurable defaults) ───────────────────────────────────
BLOCKER_AGE_ALERT_DAYS=7
MILESTONE_DUE_ALERT_DAYS=7
PM_OPEN_NEEDS_ALERT_COUNT=3
